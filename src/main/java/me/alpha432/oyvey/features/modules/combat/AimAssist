    private final ModeSetting mode = new ModeSetting("Mode", "Assist method",
        "Smooth", List.of("Smooth", "Sticky", "Hybrid", "Flick"));
    private final BooleanSetting horizontal = new BooleanSetting("Horizontal", "Pull crosshair horizontally (right-click to bind a key)", true);
    private final NumberSetting hSpeed = new NumberSetting("H Speed", "Horizontal pull strength (0 = disabled, higher = faster)", 3.0, 0.0, 20.0, 0.1);
    private final NumberSetting hMultiplier = new NumberSetting("H Multiplier", "Extra horizontal gain", 1.0, 0.0, 5.0, 0.05);
    private final NumberSetting hFov = new NumberSetting("H FOV", "Horizontal angle (deg) the assist will engage in", 80.0, 0.0, 180.0, 1.0);
    private final NumberSetting hDeadZone = new NumberSetting("H Dead Zone", "Stop pulling horizontally once within this many degrees", 0.3, 0.0, 8.0, 0.05);
    private final NumberSetting hMaxPerTick = new NumberSetting("H Max/Tick", "Hard cap on horizontal degrees per tick", 8.0, 0.0, 30.0, 0.25);
    private final BooleanSetting vertical = new BooleanSetting("Vertical", "Pull crosshair vertically (right-click to bind a key)", true);
    private final NumberSetting vSpeed = new NumberSetting("V Speed", "Vertical pull strength (0 = disabled, higher = faster)", 2.0, 0.0, 20.0, 0.1);
    private final NumberSetting vMultiplier = new NumberSetting("V Multiplier", "Extra vertical gain", 1.0, 0.0, 5.0, 0.05);
    private final NumberSetting vFov = new NumberSetting("V FOV", "Vertical angle (deg) the assist will engage in", 60.0, 0.0, 180.0, 1.0);
    private final NumberSetting vDeadZone = new NumberSetting("V Dead Zone", "Stop pulling vertically once within this many degrees", 0.3, 0.0, 8.0, 0.05);
    private final NumberSetting vMaxPerTick = new NumberSetting("V Max/Tick", "Hard cap on vertical degrees per tick", 5.0, 0.0, 30.0, 0.25);
    private final NumberSetting vOffset = new NumberSetting("V Offset", "Bias aim Y on the entity (- = aim down, + = aim up)", 0.0, -1.0, 1.0, 0.05);
    private final NumberSetting lockRange = new NumberSetting("Lock Range", "Horizontal distance to target (blocks) within which the assist engages", 4.0, 0.5, 12.0, 0.1);
    private final NumberSetting smoothness = new NumberSetting("Smoothness", "Both axes - 0 = snappy, 1 = silky", 0.55, 0.0, 1.0, 0.05);
    private final NumberSetting hSmoothnessOverride = new NumberSetting("H Smoothness", "Horizontal-only smoothness (-1 = use main slider)", -1.0, -1.0, 1.0, 0.05);
    private final NumberSetting vSmoothnessOverride = new NumberSetting("V Smoothness", "Vertical-only smoothness (-1 = use main slider)", -1.0, -1.0, 1.0, 0.05);
    private final NumberSetting stickyStrength = new NumberSetting("Sticky Strength", "How hard Sticky/Hybrid pulls when on target", 0.6, 0.0, 1.0, 0.05);
    private final NumberSetting jitter = new NumberSetting("Jitter", "Random aim offset for human-like movement", 0.0, 0.0, 2.0, 0.05);
    private final NumberSetting chance = new NumberSetting("Chance", "Per-target probability the assist engages (100 = always)", 100.0, 1.0, 100.0, 1.0);
    private final NumberSetting prediction = new NumberSetting("Prediction", "Lead moving targets (0 = none, 1 = full velocity lead)", 1.0, 0.0, 2.0, 0.05);
    private final NumberSetting hybridBlend = new NumberSetting("Hybrid Blend", "Angle (deg) over which Hybrid fades smooth -> sticky", 6.0, 1.0, 20.0, 0.5);
    private final TextSetting targetPlayer = new TextSetting("Target Player", "Only assist toward this username (blank = any)", "");
    private final BooleanSetting strictUsername = new BooleanSetting("Strict Username", "If username is set and player isn't visible, don't aim at anyone", false);
    private final NumberSetting range = new NumberSetting("Range", "Max target distance", 4.5, 0.0, 12.0, 0.1);
    private final BooleanSetting targetPlayers = new BooleanSetting("Players", "Assist toward players", true);
    private final BooleanSetting targetHostiles = new BooleanSetting("Hostiles", "Assist toward hostile mobs", false);
    private final BooleanSetting targetAnimals = new BooleanSetting("Animals", "Assist toward animals", false);
    private final BooleanSetting visibilityCheck = new BooleanSetting("Visibility", "Only assist toward visible targets (no wall aim)", true);
    private final BooleanSetting targetLock = new BooleanSetting("Target Lock", "Stay locked on same target until it leaves range/FOV", true);
    private final BooleanSetting lowHpPriority = new BooleanSetting("Low HP Priority", "Prefer the lowest-HP target when scoring", false);
    private final BooleanSetting lockLastHit = new BooleanSetting("Lock Last Hit", "Hard-lock onto the player you most recently swung on", false);
    private final NumberSetting lastHitMemory = new NumberSetting("Last Hit Memory", "How long to keep preferring the last-hit target (ms)", 4000.0, 500.0, 15000.0, 100.0);
    private final ModeSetting aimPoint = new ModeSetting("Aim Point", "Where to aim on the entity",
        "Body", List.of("Head", "Body", "Feet", "Nearest"));
    private final BooleanSetting onlyAttacking = new BooleanSetting("Only Attacking", "Only assist when holding attack button", false);
    private final BooleanSetting weaponOnly = new BooleanSetting("Weapon Only", "Only assist when holding a weapon", true);

    private Entity targetLocked = null;
    private final Random random = new Random();
    private Entity chanceSkipTarget = null;
    private boolean chancePassed = false;
    private Entity chanceTarget = null;
    private Entity currentTarget = null;
    private boolean isLastHitLocked = false;
    private double smoothProgress = 0.0;
    private boolean inDeadZoneH = false;
    private boolean inDeadZoneV = false;
    private Vec3d velocitySmooth = Vec3d.ZERO;

    public AimAssist() {
